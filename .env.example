# API keys for optional external services
VIRUSTOTAL_API_KEY=
CTI_PLATFORM_API_KEY=

# RAG layer (optional)
LLM_API_ENDPOINT=
LLM_MODEL_NAME=llama4-scout

# Training pipeline
# Max parallel workers for .eml feature extraction (default: 4)
EML_EXTRACT_MAX_WORKERS=6
# Fraction of legitimate emails augmented with modern auth headers (default: 0.70)
EML_AUGMENT_RATIO=0.70
# Fraction of malicious emails augmented to simulate a compromised inbox with valid metrics (default: 0.50)
EML_COMPROMISED_RATIO=0.10

# General
LOG_LEVEL=INFO
ENVIRONMENT=development
